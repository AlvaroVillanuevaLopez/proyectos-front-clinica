---
import { Icon } from "astro-icon/components";

const correo = "recepcion@clinicahermosilla57.com";
const telefono = "+34 91 310 51 52";
---

<div class="bg-gray-100 py-4">
  <div class="max-w-6xl mx-auto md:grid md:grid-cols-2">

    <div class="font-semibold text-gray-500 flex items-center gap-6">

      <div class="flex items-center gap-2">
        <Icon name="heroicons:envelope" class="w-4 h-4" />
        <a href={`mailto:${correo}`} class="text-sm">{correo}</a>
      </div>

      <div class="flex items-center gap-2">
        <Icon name="heroicons:phone" class="w-4 h-4" />
        <a href={`tel:${telefono}`} class="text-xs">{telefono}</a>
      </div>

    </div>

    <div class="justify-self-end">
      <a class="bg-pink-600 text-white font-semibold px-5 py-2 text-xs">
        PEDIR CITA
      </a>
    </div>

  </div>
</div>